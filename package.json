{
  "name": "my-monorepo",
  "private": true,
  "workspaces": [
    "api",
    "web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=api\" \"npm run start --workspace=web\"",
    "dev:api": "npm run dev --workspace=api",
    "dev:web": "npm run start --workspace=web",
    "build": "npm run build --workspace=api && npm run build --workspace=web",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "prisma": "^7.8.0",
    "tsx": "^4.22.0"
  },
  "dependencies": {
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2"
  }
}
